---
import GameLayout from '../layouts/game.astro';
import { getAllGameData } from '../game/data';

const data = getAllGameData();
const { profile } = data;
---

<GameLayout title="Resume — 25DGAME">
  <main
    style={{
      maxWidth: 800,
      margin: '0 auto',
      padding: '40px 24px',
      background: '#0A0A0A',
      color: '#f5f5f5',
      fontFamily: "'Inter', sans-serif",
      minHeight: '100vh',
    }}
  >
    <header style={{ marginBottom: 40 }}>
      <h1 style={{ fontSize: '2.5rem', fontWeight: 900, color: '#F0E040', fontFamily: "'Impact', sans-serif", margin: 0 }}>
        {profile.name}
      </h1>
      <p style={{ color: '#aaa', fontSize: '1.1rem', margin: '4px 0' }}>{profile.headline}</p>
      <p style={{ color: '#888', margin: '4px 0 16px' }}>{profile.tagline}</p>
      <div style={{ display: 'flex', gap: 16, flexWrap: 'wrap', color: '#888', fontSize: 14 }}>
        <span>📍 {profile.location}</span>
        <span>⏱ {profile.metrics.yearsExperience}+ years</span>
        <span>📦 {profile.metrics.projectsShipped} projects</span>
        <span>🏅 {profile.metrics.certifications} certifications</span>
      </div>
      <div style={{ display: 'flex', gap: 12, marginTop: 16 }}>
        {profile.contact.email && <span style={{ color: '#888', fontSize: 13 }}>✉ {profile.contact.email}</span>}
        {profile.contact.phone && <span style={{ color: '#888', fontSize: 13 }}>📞 {profile.contact.phone}</span>}
      </div>
      <div style={{ display: 'flex', gap: 12, marginTop: 8 }}>
        {profile.contact.linkedin && (
          <a href={profile.contact.linkedin} target="_blank" rel="noopener noreferrer" style={{ color: '#F0E040', fontFamily: "'JetBrains Mono', monospace", fontSize: 13 }}>LinkedIn ↗</a>
        )}
        {profile.contact.github && (
          <a href={profile.contact.github} target="_blank" rel="noopener noreferrer" style={{ color: '#F0E040', fontFamily: "'JetBrains Mono', monospace", fontSize: 13 }}>GitHub ↗</a>
        )}
        {profile.contact.website && (
          <a href={profile.contact.website} target="_blank" rel="noopener noreferrer" style={{ color: '#F0E040', fontFamily: "'JetBrains Mono', monospace", fontSize: 13 }}>Website ↗</a>
        )}
      </div>
    </header>

    <section style={{ marginBottom: 40 }}>
      <h2 style={{ color: '#F0E040', fontFamily: "'Impact', sans-serif", fontSize: '1.5rem', borderBottom: '1px solid #333', paddingBottom: 8, marginBottom: 12 }}>About</h2>
      <p style={{ lineHeight: 1.7, color: '#ccc' }}>{profile.summary}</p>
    </section>

    <section style={{ marginBottom: 40 }}>
      <h2 style={{ color: '#F0E040', fontFamily: "'Impact', sans-serif", fontSize: '1.5rem', borderBottom: '1px solid #333', paddingBottom: 8, marginBottom: 12 }}>Experience</h2>
      {data.experiences.map((exp) => (
        <div key={exp.id} style={{ borderLeft: '2px solid #F0E040', paddingLeft: 16, marginBottom: 20 }}>
          <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start' }}>
            <div>
              <h3 style={{ color: '#f5f5f5', fontSize: '1rem', margin: 0 }}>{exp.role}</h3>
              <p style={{ color: '#888', fontSize: 13, margin: '4px 0' }}>{exp.company}</p>
            </div>
            <span style={{
              background: 'transparent',
              border: '1px solid #555',
              color: '#888',
              padding: '2px 8px',
              borderRadius: 4,
              fontSize: 11,
              fontFamily: "'JetBrains Mono', monospace",
              whiteSpace: 'nowrap',
            }}>
              {exp.type}
            </span>
          </div>
          <p style={{ color: '#666', fontSize: 12, fontFamily: "'JetBrains Mono', monospace", margin: '4px 0 8px' }}>
            {exp.startDate} – {exp.endDate || 'Present'} · {exp.location}
          </p>
          <ul style={{ margin: '8px 0', paddingLeft: 20, color: '#aaa', fontSize: 13, lineHeight: 1.6 }}>
            {exp.highlights.map((h, i) => <li key={i}>{h}</li>)}
          </ul>
          <div style={{ display: 'flex', gap: 6, flexWrap: 'wrap' }}>
            {exp.technologies.map((t) => (
              <span key={t} style={{ border: '1px solid #333', color: '#666', padding: '2px 8px', borderRadius: 4, fontSize: 11, fontFamily: "'JetBrains Mono', monospace" }}>{t}</span>
            ))}
          </div>
        </div>
      ))}
    </section>

    <section style={{ marginBottom: 40 }}>
      <h2 style={{ color: '#F0E040', fontFamily: "'Impact', sans-serif", fontSize: '1.5rem', borderBottom: '1px solid #333', paddingBottom: 8, marginBottom: 12 }}>Skills</h2>
      {data.skills.map((cat) => (
        <div key={cat.name} style={{ marginBottom: 16 }}>
          <h3 style={{ color: '#aaa', fontSize: '0.9rem', marginBottom: 8 }}>{cat.name}</h3>
          <div style={{ display: 'flex', gap: 8, flexWrap: 'wrap' }}>
            {cat.skills.map((skill) => (
              <span key={skill.name} style={{ border: '1px solid #F0E040', color: '#F0E040', padding: '4px 12px', borderRadius: 4, fontSize: 12, fontFamily: "'JetBrains Mono', monospace" }}>
                {skill.name}
              </span>
            ))}
          </div>
        </div>
      ))}
    </section>

    <section style={{ marginBottom: 40 }}>
      <h2 style={{ color: '#F0E040', fontFamily: "'Impact', sans-serif", fontSize: '1.5rem', borderBottom: '1px solid #333', paddingBottom: 8, marginBottom: 12 }}>Projects</h2>
      <div style={{ display: 'grid', gap: 16, gridTemplateColumns: 'repeat(auto-fill, minmax(280px, 1fr))' }}>
        {data.projects.map((project) => (
          <div key={project.id} style={{ background: '#1a1a1a', border: project.featured ? '1px solid #F0E040' : '1px solid #333', borderRadius: 4, padding: 16 }}>
            <h3 style={{ color: '#f5f5f5', fontSize: '0.95rem', margin: '0 0 4px' }}>{project.title}</h3>
            <p style={{ color: '#888', fontSize: 12, margin: '0 0 8px' }}>{project.category} · {project.period}</p>
            <p style={{ color: '#aaa', fontSize: 13, lineHeight: 1.5, margin: '0 0 8px' }}>{project.description}</p>
            <div style={{ display: 'flex', gap: 6, flexWrap: 'wrap' }}>
              {project.skills.map((s) => <span key={s} style={{ color: '#666', fontSize: 11, fontFamily: "'JetBrains Mono', monospace" }}>{s}</span>)}
            </div>
            {project.links.length > 0 && (
              <div style={{ marginTop: 8, display: 'flex', gap: 8 }}>
                {project.links.map((link) => (
                  <a key={link.label} href={link.url} target="_blank" rel="noopener noreferrer" style={{ color: '#F0E040', fontSize: 12, fontFamily: "'JetBrains Mono', monospace" }}>{link.label} ↗</a>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>
    </section>

    <section style={{ marginBottom: 40 }}>
      <h2 style={{ color: '#F0E040', fontFamily: "'Impact', sans-serif", fontSize: '1.5rem', borderBottom: '1px solid #333', paddingBottom: 8, marginBottom: 12 }}>Certifications</h2>
      <div style={{ display: 'flex', flexWrap: 'wrap', gap: 6 }}>
        {data.certifications.map((cert) => (
          <span key={cert.id} style={{ border: '1px solid #555', color: '#aaa', padding: '4px 10px', borderRadius: 4, fontSize: 12, fontFamily: "'JetBrains Mono', monospace" }}>{cert.title}</span>
        ))}
      </div>
    </section>

    <section style={{ marginBottom: 40 }}>
      <h2 style={{ color: '#F0E040', fontFamily: "'Impact', sans-serif", fontSize: '1.5rem', borderBottom: '1px solid #333', paddingBottom: 8, marginBottom: 12 }}>Honors</h2>
      {data.honors.map((honor) => (
        <div key={honor.id} style={{ marginBottom: 12 }}>
          <h3 style={{ color: '#f5f5f5', fontSize: '0.95rem', margin: '0 0 2px' }}>{honor.title}</h3>
          <p style={{ color: '#888', fontSize: 13, margin: 0 }}>{honor.event} · {honor.date}</p>
          {honor.description && <p style={{ color: '#aaa', fontSize: 13, margin: '4px 0 0' }}>{honor.description}</p>}
        </div>
      ))}
    </section>

    <section style={{ marginBottom: 40 }}>
      <h2 style={{ color: '#F0E040', fontFamily: "'Impact', sans-serif", fontSize: '1.5rem', borderBottom: '1px solid #333', paddingBottom: 8, marginBottom: 12 }}>Volunteering</h2>
      {data.volunteering.map((vol) => (
        <div key={vol.id} style={{ marginBottom: 12 }}>
          <h3 style={{ color: '#f5f5f5', fontSize: '0.95rem', margin: '0 0 2px' }}>{vol.role}</h3>
          <p style={{ color: '#888', fontSize: 13, margin: 0 }}>{vol.organization} · {vol.cause}</p>
          <p style={{ color: '#666', fontSize: 12, margin: '2px 0 0' }}>{vol.startDate} – {vol.endDate}</p>
          <ul style={{ margin: '4px 0', paddingLeft: 20, color: '#aaa', fontSize: 13 }}>
            {vol.highlights.map((h, i) => <li key={i}>{h}</li>)}
          </ul>
        </div>
      ))}
    </section>

    <footer style={{ borderTop: '1px solid #333', paddingTop: 24, textAlign: 'center' }}>
      <p style={{ color: '#555', fontSize: 12 }}>25DGAME · Interactive Portfolio · {profile.name}</p>
      <p style={{ color: '#444', fontSize: 11, marginTop: 4 }}>This resume is auto-generated from the 25DGAME data layer.</p>
    </footer>
  </main>
</GameLayout>

<style is:global>
  html, body { margin: 0; padding: 0; background: #0A0A0A; }
  a { text-decoration: none; }
  a:hover { text-decoration: underline; }
  @media print {
    main { padding: 0 !important; }
    a { color: #000 !important; }
  }
</style>
