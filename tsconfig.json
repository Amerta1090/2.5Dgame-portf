{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "paths": {
      "@data/*": ["./data/*"],
      "@game/*": ["./src/game/*"]
    },
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "types": ["node"]
  },
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist"]
}
